--- !u!114 &996207074
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 996207073}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fa3edabb3c788e2438d38ab83e37d4f8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueConversationData
  conversationId: ENTER_HOUSE
  allowSkip: 1
  skipButtonText: "B\u1ECF qua h\u01B0\u1EDBng d\u1EABn"
  defaultSecondsPerCharacter: 0.00075
  returnCameraToPlayerOnEnd: 1
  returnCameraMoveTime: 0.3
  lines:
  - speaker: {fileID: 11400000, guid: 0a1f16f04e824c84196c75d662c6a618, type: 2}
    content: "\u0110\xE3 x\xE2m nh\u1EADp th\xE0nh c\xF4ng."
    cameraMode: 3
    customCameraTarget: {fileID: 0}
    cameraMoveTime: 0.75
    waitForCameraBeforeTyping: 1
    secondsPerCharacterOverride: -1
    waitAfterTypingBeforeContinue: 0
  - speaker: {fileID: 11400000, guid: ab24398083758814e99f21fc8af11dae, type: 2}
    content: "T\u1ED1t. Ph\xE1t hi\u1EC7n m\u1ED9t chi\u1EBFc ch\xECa kh\xF3a tr\xEAn
      chi\u1EBFc b\xE0n \u1EDF c\u0103n ph\xF2ng k\u1EBF b\xEAn. Ti\u1EBFp c\u1EADn
      v\xE0 thu h\u1ED3i n\xF3.\t"
    cameraMode: 2
    customCameraTarget: {fileID: 444957913}
    cameraMoveTime: 0.25
    waitForCameraBeforeTyping: 1
    secondsPerCharacterOverride: -1
    waitAfterTypingBeforeContinue: 0
  - speaker: {fileID: 11400000, guid: 0a1f16f04e824c84196c75d662c6a618, type: 2}
    content: "R\xF5."
    cameraMode: 3
    customCameraTarget: {fileID: 0}
    cameraMoveTime: 0.75
    waitForCameraBeforeTyping: 1
    secondsPerCharacterOverride: -1
    waitAfterTypingBeforeContinue: 0
  - speaker: {fileID: 11400000, guid: ab24398083758814e99f21fc8af11dae, type: 2}
    content: "M\u1EE5c ti\xEAu ti\u1EBFp theo l\xE0 t\xECm l\u1ED1i \u0111i b\xED
      m\u1EADt. Theo d\u1EEF li\u1EC7u t\xECnh b\xE1o, c\u01A1 ch\u1EBF k\xEDch ho\u1EA1t
      \u0111\u01B0\u1EE3c gi\u1EA5u \u0111\xE2u \u0111\xF3 trong c\u0103n nh\xE0
      n\xE0y."
    cameraMode: 3
    customCameraTarget: {fileID: 0}
    cameraMoveTime: 0.75
    waitForCameraBeforeTyping: 1
    secondsPerCharacterOverride: -1
    waitAfterTypingBeforeContinue: 0
  - speaker: {fileID: 11400000, guid: ab24398083758814e99f21fc8af11dae, type: 2}
    content: "Gi\u1EEF c\u1EA3nh gi\xE1c. Ch\xFAng ta kh\xF4ng c\xF3 c\u01A1 h\u1ED9i
      th\u1EE9 hai."
    cameraMode: 3
    customCameraTarget: {fileID: 0}
    cameraMoveTime: 0.75
    waitForCameraBeforeTyping: 1
    secondsPerCharacterOverride: -1
    waitAfterTypingBeforeContinue: 0
